# ── Maya Investment WhatsApp Bot — Umgebungsvariablen ──
# Diese Werte in Ihrer Hosting-Umgebung (Railway/Render/…) als Variablen setzen.
# NICHT in Git committen!

# Anthropic (Claude) — Ihren Schlüssel hier eintragen
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Cloud API (aus dem Meta-Dashboard)
WHATSAPP_TOKEN=EAAG...                 # Access-Token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=maya-investment-verify   # frei wählbar, gleicher Wert wie im Meta-Webhook

# Ihre eigene WhatsApp-Nummer (Admin) — Format ohne + und ohne 00
ADMIN_WHATSAPP=4915112345678

# Optional
CLAUDE_MODEL=claude-opus-4-8
WHATSAPP_GRAPH_VERSION=v21.0
DB_PATH=bluecard.db
